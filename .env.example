# Copy this file to .env.local and fill in real values (see README for setup steps).

# --- Client (bundled into the app, safe to be public) ---

# Get a Gemini API key from https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Optional: override the Gemini model (defaults to gemini-3.5-flash)
# VITE_GEMINI_MODEL=gemini-3.5-flash

# Optional: model to retry on if the primary is overloaded/rate-limited
# (defaults to gemini-3.1-flash-lite)
# VITE_GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite

# --- Server (serverless functions only — never bundled into the client) ---

# Shared password admins use to sign in on the upload page.
ADMIN_PASSWORD=7867865253

# Random secret used to sign admin session tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# Auto-provided by Vercel once you create & link a Blob store — run
# `vercel env pull .env.local` to fetch it locally, no need to set it by hand.
# BLOB_READ_WRITE_TOKEN=
